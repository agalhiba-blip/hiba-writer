# ── Développement local ─────────────────────────────
# (Aucune variable requise, SQLite est utilisé automatiquement)

# ── Production Vercel ────────────────────────────────
# Base de données PostgreSQL (Neon - https://neon.tech - gratuit)
DATABASE_URL=postgresql://user:password@host/database

# Clé API Anthropic (optionnel - peut aussi être configurée dans l'interface)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
